{
  "name": "@fern-ui/button",
  "version": "0.1.0",
  "description": "A dependency-free button: seven variants, three sizes, matched to the HeroUI v3 spec.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.8",
    "react": "^19.0.0",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3"
  },
  "keywords": [
    "react",
    "button",
    "accessible",
    "unstyled",
    "tailwind"
  ],
  "publishConfig": {
    "access": "public"
  }
}
