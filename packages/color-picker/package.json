{
  "name": "@fern-ui/color-picker",
  "version": "0.1.1",
  "description": "An accessible, dependency-free color picker for React.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css",
    "./color": {
      "types": "./dist/color.d.ts",
      "import": "./dist/color.js",
      "require": "./dist/color.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rm -rf dist && tsup && tailwindcss -i src/styles.css -o dist/styles.css --minify",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.3",
    "@types/react": "^19.0.8",
    "react": "^19.0.0",
    "tailwindcss": "^4.3.3",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3"
  },
  "keywords": [
    "react",
    "color-picker",
    "colour",
    "ui",
    "accessible"
  ],
  "publishConfig": {
    "access": "public"
  }
}
